# ======================================================
# FDS IAM Playground — Environment Variables
# Copy this file to .env and fill in your values
# ======================================================

# --- Application Mode ---
# Set to true to use mock data (no real IAM required)
MOCK_MODE=false

# --- OIDC / OAuth2 Configuration ---
OIDC_ISSUER=https://your-iam.example.com/oauth
OIDC_CLIENT_ID=fds-iam-playground
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=http://localhost:3000/callback
OIDC_SCOPES=openid profile email

# --- FDS IAM Base URL ---
# Base URL for the IAM REST API (users, groups, IDP, etc.)
IAM_BASE_URL=https://your-iam.example.com

# --- Security ---
SESSION_SECRET=change-this-to-a-random-string-in-production

# --- CORS ---
CORS_ORIGIN=http://localhost:3000

# --- Ports (Docker) ---
HTTP_PORT=80
HTTPS_PORT=443

